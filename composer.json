{
    "name": "philiprehberger/laravel-healthcheck",
    "description": "Configurable health check endpoint with built-in checks and Kubernetes probe support.",
    "keywords": ["laravel", "health", "healthcheck", "kubernetes", "k8s", "monitoring"],
    "license": "MIT",
    "authors": [
        {
            "name": "Philip Rehberger",
            "email": "philip@rehberger.io"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/routing": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0",
        "laravel/pint": "^1.18",
        "phpstan/phpstan": "^2.0",
        "nunomaduro/larastan": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "PhilipRehberger\\Healthcheck\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhilipRehberger\\Healthcheck\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "PhilipRehberger\\Healthcheck\\HealthcheckServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
